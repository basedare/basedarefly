DATABASE_URL="postgresql://user:password@localhost:5432/basedare"
DIRECT_URL="postgresql://user:password@localhost:5432/basedare"

# Web3 / Base Network
NEXT_PUBLIC_NETWORK="sepolia"
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID="your_wallet_connect_project_id"
NEXT_PUBLIC_BASE_RPC_URL="https://sepolia.base.org"
NEXT_PUBLIC_BOUNTY_CONTRACT_ADDRESS="0xYourTestnetContractAddress"
NEXT_PUBLIC_USDC_ADDRESS="0xYourUsdcAddress"
NEXT_PUBLIC_PLATFORM_WALLET_ADDRESS="0xYourPlatformWalletAddress"
REFEREE_HOT_WALLET_PRIVATE_KEY="0xYourRefereeHotWalletPrivateKey"
CRON_SECRET="your_cron_secret"
INTERNAL_API_SECRET="your_internal_api_secret"
VENUE_QR_SECRET="your_dedicated_venue_qr_secret_at_least_32_chars"

# IPFS Storage (Pinata)
PINATA_JWT="your_pinata_jwt_token_here"
PINATA_GATEWAY="gateway.pinata.cloud"

# Headless Browser Testing
HYPERBROWSER_API_KEY="your_hyperbrowser_api_key"

# Telegram Admin Alerts
TELEGRAM_BOT_TOKEN="your_telegram_bot_token"
TELEGRAM_ADMIN_CHAT_ID="your_telegram_admin_chat_id"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Mission Pass (creator attribution + passwordless mission recovery)
# Use a dedicated random secret (at least 32 characters). Never reuse a wallet key.
MISSION_PASS_HMAC_SECRET="replace_with_a_dedicated_random_secret_at_least_32_chars"
RESEND_API_KEY="re_your_resend_api_key"
MISSION_PASS_FROM_EMAIL="BaseDare <missions@your-verified-domain.example>"

# Analytics (PostHog) — leave unset to disable; analytics safely no-ops without it.
# Get the Project API key from PostHog → Project Settings. Use the EU host if your
# project is in the EU region (https://eu.i.posthog.com).
NEXT_PUBLIC_POSTHOG_KEY="phc_your_posthog_project_api_key"
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
