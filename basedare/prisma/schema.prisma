generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              String     @id @default(cuid())
  walletAddress   String     @unique
  baseTag         String     @unique
  reputationScore Int        @default(0)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  dares           Dare[]
  referrals       Referral[]
}

model Dare {
  id                  String    @id @default(cuid())
  shortId             String?   @unique
  onChainDareId       String?   @unique
  title               String
  missionMode         String?   @default("IRL")
  tag                 String?
  bounty              Float
  upvoteCount         Int       @default(0)
  streamerHandle      String?
  status              String    @default("PENDING")
  videoUrl            String?
  imageUrl            String?
  proofHash           String?
  proofCid            String? // Store the IPFS CID from Pinata
  imageCid            String?
  requireSentinel     Boolean   @default(false)
  sentinelVerified    Boolean   @default(false)
  manualReviewNeeded  Boolean   @default(false)
  creatorId           String?
  streamId            String?
  txHash              String?
  isSimulated         Boolean   @default(false)
  expiresAt           DateTime?
  verifiedAt          DateTime?
  verifyTxHash        String?
  verifyConfidence    Float?
  appealStatus        String?
  appealReason        String?
  appealedAt          DateTime?
  referrerTag         String?
  referrerAddress     String?
  referrerPayout      Float?
  stakerAddress       String?
  venueId             String?
  inviteToken         String?   @unique
  claimDeadline       DateTime?
  targetWalletAddress String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  // Self-expiring lease so only ONE retry-payouts worker processes a
  // PENDING_PAYOUT row at a time (set atomically via CAS; ignored once stale).
  payoutLeaseAt       DateTime?
  discoveryRadiusKm   Float?    @default(5)
  geohash             String?
  isNearbyDare        Boolean   @default(false)
  latitude            Float?
  locationLabel       String?
  longitude           Float?
  venue_key           String?
  dare_text           String?
  proof_media         String?
  completed_at        DateTime?
  reaction_count      Int       @default(0)
  geo_bucket          String?
  // Claim-to-attempt fields (for @everyone open dares)
  claimedBy           String? // Wallet that claimed this dare
  claimedAt           DateTime? // When it was claimed
  claimExpiresAt      DateTime? // When the claim expires (24h window)
  // Claim request fields (moderated claim flow for open dares)
  claimRequestWallet  String? // Wallet requesting to claim
  claimRequestTag     String? // Tag of the requester (e.g., @username)
  claimRequestedAt    DateTime? // When request was submitted
  claimRequestStatus  String? // PENDING, APPROVED, REJECTED
  // Moderator decision fields
  moderatorDecision   String? // APPROVED or REJECTED
  moderatorAddress    String? // Wallet of moderator who decided
  moderatedAt         DateTime? // When moderation happened
  moderatorNote       String? // Optional note from moderator
  // Versioned policy snapshot compiled before funding. The database migration
  // prevents mutation once set so payout and receipts always use the contract
  // the buyer actually funded.
  outcomeContractFamily   String?
  outcomeContractVersion  Int?
  outcomeContractSnapshot Json?
  // These truths are deliberately separate: what the contributor observed is
  // not the same thing as whether BaseDare accepted the supporting evidence.
  reportedOutcome         Json?
  evidenceDecision        String? // PENDING_REVIEW | ACCEPTED | REJECTED
  orchestrationDecision   Json? // Reserved for the operator Dare Director.
  // Vote threshold tracking
  voteThreshold       Int       @default(5) // Votes needed for mod review
  creator             User?     @relation(fields: [creatorId], references: [id])
  venue               Venue?    @relation(fields: [venueId], references: [id])
  linkedCampaign      Campaign? @relation("CampaignLinkedDare")
  votes               Vote[]
  comments            Comment[]
  creatorReview       CreatorReview?
  inboxThreads        InboxThread[]
  proofAttempts       DareProofAttempt[]

  @@index([inviteToken])
  @@index([streamerHandle, status])
  @@index([geohash])
  @@index([isNearbyDare, status])
  @@index([claimedBy])
  @@index([status, videoUrl])
  @@index([claimRequestStatus])
  @@index([tag])
  @@index([geo_bucket])
  @@index([venueId, status])
}

// Append-only evidence ledger for proof attempts. One row per submission
// (web / internal / telegram / retry / appeal); rows are NEVER updated or
// overwritten — retries and disputes add new rows. Dare caches the latest proof
// state; THIS is the audit log. Exact submitted coordinates are private
// (server-only); public receipts expose only the proximity outcome.
model DareProofAttempt {
  id                 String    @id @default(cuid())
  dareId             String
  submitterWallet    String?
  beneficiaryWallet  String?
  source             String    @default("web") // web | internal | telegram | retry | appeal
  systemActor        String?
  // Target snapshot at attempt time (never mutated after write).
  targetLatitude     Float?
  targetLongitude    Float?
  allowedRadiusKm    Float?
  // Device-reported evidence (private — never exposed at precise resolution).
  submittedLatitude  Float?
  submittedLongitude Float?
  accuracyM          Float?
  capturedAt         DateTime?
  receivedAt         DateTime  @default(now())
  // Computed proximity result.
  distanceKm         Float?
  proximityDecision  String? // INSIDE | REVIEW | REJECT
  proximityCode      String?
  // Media + overall attempt outcome.
  mediaCid           String?
  mediaHash          String?
  verificationConfidence Float?
  verificationReason String?
  proximityReason    String?
  decision           String? // e.g. AUTO_APPROVED | PENDING_REVIEW | REJECTED
  reportedOutcome    Json?
  evidenceDecision   String? // PENDING_REVIEW | ACCEPTED | REJECTED at attempt time
  reason             String?
  decidedAt          DateTime?
  // Stable per-(dare, media) idempotency key: `${dareId}:${proofCid||videoUrl}`.
  // NULL when no media is attached (Postgres treats NULLs as distinct, so
  // no-media rows never collide). The unique index blocks replaying the same
  // media to the same dare with a fresh location.
  submissionKey      String?
  createdAt          DateTime  @default(now())

  dare               Dare      @relation(fields: [dareId], references: [id], onDelete: Cascade)

  @@unique([dareId, submissionKey])
  @@index([dareId, createdAt])
  @@index([submitterWallet])
}

model CreatorReview {
  id             String   @id @default(cuid())
  dareId         String   @unique
  creatorTag     String
  reviewerWallet String
  rating         Int
  review         String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  dare           Dare     @relation(fields: [dareId], references: [id], onDelete: Cascade)

  @@index([creatorTag, createdAt])
  @@index([reviewerWallet, createdAt])
}

model Venue {
  id                  String           @id @default(cuid())
  slug                String           @unique
  name                String
  description         String?
  address             String?
  city                String?
  country             String?
  latitude            Float
  longitude           Float
  geohash             String?
  timezone            String           @default("UTC")
  categories          String[]         @default([])
  status              String           @default("ACTIVE")
  isPartner           Boolean          @default(false)
  partnerTier         String?
  placeSource         String?
  externalPlaceId     String?
  qrMode              String           @default("ROTATING")
  qrRotationSeconds   Int              @default(45)
  checkInRadiusMeters Int              @default(120)
  claimedBy           String?
  claimedAt           DateTime?
  claimRequestWallet  String?
  claimRequestTag     String?
  claimRequestedAt    DateTime?
  claimRequestStatus  String?
  moderatorAddress    String?
  moderatedAt         DateTime?
  moderatorNote       String?
  hoursJson           Json?
  metadataJson        Json?
  discoveryScoutId    String?
  activeScoutId       String?
  activeRakeReviewedAt DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  dares               Dare[]
  campaigns           Campaign[]
  inboxThreads        InboxThread[]
  checkIns            VenueCheckIn[]
  memories            VenueMemory[]
  placeTags           PlaceTag[]
  qrSessions          VenueQrSession[]
  reviews             VenueReview[]
  roomMessages        VenueRoomMessage[]
  roomPresences       VenueRoomPresence[]
  contactRoutes       VenueContactRoute[]
  reportEvents        VenueReportEvent[]
  reportLeads         VenueReportLead[]
  founderEvents       FounderEvent[]
  baseCashCredits     BaseCashVenueCredit[]
  fieldStationLinks   CreatorAttributionLink[] @relation("FieldStationHostVenue")
  discoveryScout      Scout?              @relation("VenueDiscoveryScout", fields: [discoveryScoutId], references: [id])
  activeScout         Scout?              @relation("VenueActiveScout", fields: [activeScoutId], references: [id])

  @@unique([placeSource, externalPlaceId])
  @@index([status])
  @@index([geohash])
  @@index([city, status])
  @@index([claimRequestStatus])
  @@index([claimedBy])
  @@index([discoveryScoutId])
  @@index([activeScoutId])
}

model VenueContactRoute {
  id                 String   @id @default(cuid())
  venueId            String
  channel            String
  label              String
  purpose            String?
  url                String
  responseHours      String?
  source             String
  sourceUrl          String?
  consentBasis       String
  isPersonal         Boolean  @default(false)
  isPublic           Boolean  @default(false)
  active             Boolean  @default(true)
  verificationStatus String   @default("PENDING")
  verifiedAt         DateTime?
  verifiedBy         String?
  lastConfirmedAt    DateTime?
  sortOrder          Int      @default(0)
  createdBy          String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  venue              Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([venueId, active, isPublic, verificationStatus, sortOrder])
  @@index([venueId, channel])
  @@index([lastConfirmedAt])
}

model BaseCashVenueCredit {
  id                 String   @id @default(cuid())
  venueId            String
  buyerWallet        String
  buyerTag           String?
  receiptCode        String   @unique
  denominationPhp    Int
  serviceFeePhp      Int
  totalPhp           Int
  venueReceivablePhp Int
  currencyPaid       String   @default("USDC")
  chainId            Int      @default(8453)
  txHash             String?
  paymentStatus      String   @default("PENDING")
  redemptionStatus   String   @default("ACTIVE")
  settlementStatus   String   @default("UNSETTLED")
  validFrom          DateTime @default(now())
  expiresAt          DateTime
  redeemedAt         DateTime?
  redeemedBy         String?
  settlementReference String?
  metadataJson       Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  venue              Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([venueId, createdAt])
  @@index([venueId, paymentStatus, redemptionStatus])
  @@index([receiptCode])
  @@index([buyerWallet, createdAt])
  @@index([settlementStatus])
}

model FounderEvent {
  id           String   @id @default(cuid())
  eventType    String
  source       String   @default("server")
  subjectType  String?
  subjectId    String?
  dedupeKey    String   @unique
  title        String?
  amount       Float?
  status       String?
  actor        String?
  href         String?
  venueId      String?
  venueSlug    String?
  metadataJson Json?
  occurredAt   DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  venue        Venue?   @relation(fields: [venueId], references: [id], onDelete: SetNull)

  @@index([eventType, occurredAt])
  @@index([subjectType, subjectId])
  @@index([venueId, occurredAt])
  @@index([occurredAt])
}

model VenueReportEvent {
  id         String   @id @default(cuid())
  venueId     String
  leadId      String?
  audience    String   @default("venue")
  eventType   String
  sessionKey  String?
  channel     String?
  metadataJson Json?
  createdAt   DateTime @default(now())
  venue       Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)
  lead        VenueReportLead? @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([venueId, createdAt])
  @@index([venueId, eventType, createdAt])
  @@index([sessionKey, createdAt])
}

model VenueReportLead {
  id          String   @id @default(cuid())
  venueId      String
  audience     String   @default("venue")
  source       String   @default("REPORT")
  intent       String?
  sessionKey   String?
  email        String
  name         String?
  organization String?
  notes        String?
  followUpStatus String @default("NEW")
  ownerWallet    String?
  nextActionAt   DateTime?
  contactedAt  DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  venue        Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)
  reportEvents VenueReportEvent[]

  @@index([venueId, createdAt])
  @@index([venueId, audience, createdAt])
  @@index([email, createdAt])
  @@index([sessionKey, createdAt])
  @@index([followUpStatus, contactedAt])
  @@index([ownerWallet, contactedAt])
}

model PlaceTag {
  id                String   @id @default(cuid())
  venueId           String
  walletAddress     String
  creatorTag        String?
  status            String   @default("PENDING")
  caption           String?
  vibeTags          String[] @default([])
  proofMediaUrl     String
  proofCid          String?
  proofHash         String?
  proofType         String   @default("IMAGE")
  source            String   @default("DIRECT_TAG")
  linkedDareId      String?
  hiddenPromptId    String?
  latitude          Float?
  longitude         Float?
  geoDistanceMeters Int?
  heatContribution  Int      @default(10)
  firstMark         Boolean  @default(false)
  // Immutable global receipt serial — assigned exactly once, inside the same
  // transaction that makes the tag APPROVED. Never recomputed, never reused.
  serialNumber      Int?     @unique
  submittedAt       DateTime @default(now())
  reviewedAt        DateTime?
  reviewerWallet    String?
  reviewReason      String?
  metadataJson      Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  venue             Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([venueId, submittedAt])
  @@index([venueId, status, submittedAt])
  @@index([walletAddress, submittedAt])
  @@index([creatorTag, submittedAt])
  @@index([linkedDareId])
}

model VenueCheckIn {
  id                String          @id @default(cuid())
  venueId           String
  walletAddress     String
  tag               String?
  dareId            String?
  status            String          @default("CONFIRMED")
  proofLevel        String          @default("QR_AND_GPS")
  source            String          @default("VENUE_QR")
  venueSessionId    String?
  qrTokenHash       String?
  geoDistanceMeters Int?
  scannedAt         DateTime        @default(now())
  windowStartAt     DateTime?
  windowEndAt       DateTime?
  metadataJson      Json?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  venue             Venue           @relation(fields: [venueId], references: [id], onDelete: Cascade)
  session           VenueQrSession? @relation(fields: [venueSessionId], references: [id], onDelete: SetNull)
  reviews           VenueReview[]

  @@index([venueId, scannedAt])
  @@index([venueSessionId])
  @@index([walletAddress, scannedAt])
  @@index([tag])
  @@index([dareId])
  @@index([status])
}

model VenueReview {
  id             String        @id @default(cuid())
  venueId        String
  walletAddress  String
  tag            String?
  checkInId      String?
  verdict        String
  note           String?
  confirmations  Int           @default(0)
  status         String        @default("ACTIVE")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  venue          Venue         @relation(fields: [venueId], references: [id], onDelete: Cascade)
  checkIn        VenueCheckIn? @relation(fields: [checkInId], references: [id], onDelete: SetNull)

  @@unique([venueId, walletAddress])
  @@index([venueId, createdAt])
  @@index([walletAddress, createdAt])
  @@index([checkInId])
  @@index([status])
}

model VenueMemory {
  id                  String   @id @default(cuid())
  venueId             String
  bucketType          String   @default("DAY")
  bucketStartAt       DateTime
  bucketEndAt         DateTime
  checkInCount        Int      @default(0)
  uniqueVisitorCount  Int      @default(0)
  dareCount           Int      @default(0)
  completedDareCount  Int      @default(0)
  proofCount          Int      @default(0)
  perkRedemptionCount Int      @default(0)
  topCreatorTag       String?
  topMomentDareId     String?
  metadataJson        Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  venue               Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([venueId, bucketType, bucketStartAt])
  @@index([venueId, bucketStartAt])
}

model VenueQrSession {
  id              String         @id @default(cuid())
  venueId         String
  scope           String         @default("VENUE_CHECKIN")
  sessionKey      String         @unique
  status          String         @default("LIVE")
  label           String?
  campaignLabel   String?
  rotationSeconds Int            @default(45)
  startedAt       DateTime       @default(now())
  endsAt          DateTime?
  lastRotatedAt   DateTime       @default(now())
  pausedAt        DateTime?
  lastCheckInAt   DateTime?
  metadataJson    Json?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  venue           Venue          @relation(fields: [venueId], references: [id], onDelete: Cascade)
  checkIns        VenueCheckIn[]

  @@index([venueId, status])
  @@index([startedAt])
}

model VenueRoomMessage {
  id            String   @id @default(cuid())
  venueId       String
  walletAddress String
  displayName   String   @default("Anonymous")
  avatarUrl     String?
  body          String
  expiresAt     DateTime
  metadataJson  Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  venue         Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([venueId, expiresAt, createdAt])
  @@index([venueId, walletAddress, createdAt])
  @@index([walletAddress, createdAt])
}

model VenueRoomPresence {
  id            String   @id @default(cuid())
  venueId       String
  walletAddress String
  displayName   String   @default("Anonymous")
  avatarUrl     String?
  visibility    String   @default("PUBLIC")
  source        String   @default("ROOM")
  lastSeenAt    DateTime @default(now())
  expiresAt     DateTime
  metadataJson  Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  venue         Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([venueId, walletAddress])
  @@index([venueId, visibility, expiresAt, lastSeenAt])
  @@index([walletAddress, lastSeenAt])
}

model AppSettings {
  id                          String    @id @default("singleton")
  sentinelEnabled             Boolean   @default(true)
  sentinelPausedReason        String?
  sentinelPendingAlertThreshold Int     @default(5)
  lastSentinelQueueAlertSent  DateTime?
  venueLeadAlertThreshold     Int       @default(2)
  lastVenueLeadAlertSent      DateTime?
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt
}

model Comment {
  id            String   @id @default(cuid())
  dareId        String
  walletAddress String
  displayName   String   @default("Anonymous")
  body          String
  createdAt     DateTime @default(now())
  dare          Dare     @relation(fields: [dareId], references: [id], onDelete: Cascade)

  @@index([dareId, createdAt])
}

model Referral {
  id          String   @id @default(cuid())
  code        String   @unique
  ownerId     String
  usageCount  Int      @default(0)
  totalEarned Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  owner       User     @relation(fields: [ownerId], references: [id])
}

model StreamerTag {
  id                   String    @id @default(cuid())
  tag                  String    @unique
  walletAddress        String
  bio                  String?
  pfpUrl               String?
  pfpScale             Float     @default(1)
  pfpOffsetX           Float     @default(50)
  pfpOffsetY           Float     @default(50)
  followerCount        Int?
  tags                 String[]  @default([])
  verificationMethod   String
  identityPlatform     String?
  identityHandle       String?
  identityVerificationCode String?
  verifiedAt           DateTime?
  twitterId            String?   @unique
  twitterHandle        String?
  twitterVerified      Boolean   @default(false)
  twitchId             String?   @unique
  twitchHandle         String?
  twitchVerified       Boolean   @default(false)
  youtubeId            String?   @unique
  youtubeHandle        String?
  youtubeVerified      Boolean   @default(false)
  kickHandle           String?
  kickVerificationCode String?
  kickVerified         Boolean   @default(false)
  status               String    @default("PENDING")
  revokedAt            DateTime?
  revokedBy            String?
  revokeReason         String?
  totalEarned          Float     @default(0)
  completedDares       Int       @default(0)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([walletAddress])
  @@index([twitterHandle])
  @@index([identityPlatform, identityHandle])
  @@index([identityHandle])
  @@index([status])
}

model Brand {
  id            String     @id @default(cuid())
  name          String
  logo          String?
  walletAddress String     @unique
  verified      Boolean    @default(false)
  totalSpend    Float      @default(0)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  campaigns     Campaign[]
}

model Campaign {
  id                   String         @id @default(cuid())
  shortId              String         @unique @default(cuid())
  brandId              String
  type                 String         @default("CREATOR")
  tier                 String
  title                String
  description          String?
  budgetUsdc           Float
  creatorCountTarget   Int
  payoutPerCreator     Float
  venueId              String?
  linkedDareId         String?        @unique
  targetingCriteria    String         @default("{}")
  verificationCriteria String         @default("{}")
  syncTime             DateTime?
  windowHours          Int            @default(24)
  strikeWindowMinutes  Int            @default(10)
  precisionMultiplier  Float          @default(1.0)
  status               String         @default("DRAFT")
  vetoWindowEndsAt     DateTime?
  vetoCount            Int            @default(0)
  maxVetoPercent       Int            @default(25)
  rakePercent          Int            @default(30)
  fundedAt             DateTime?
  liveAt               DateTime?
  settledAt            DateTime?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  brand                Brand          @relation(fields: [brandId], references: [id])
  venue                Venue?         @relation(fields: [venueId], references: [id])
  linkedDare           Dare?          @relation("CampaignLinkedDare", fields: [linkedDareId], references: [id])
  slots                CampaignSlot[]
  inboxThreads         InboxThread[]

  @@index([type, status])
  @@index([venueId, status])
}

model CampaignSlot {
  id               String    @id @default(cuid())
  campaignId       String
  scoutId          String?
  creatorAddress   String?
  creatorHandle    String?
  creatorFollowers Int?
  claimRationale   String?
  claimedAt        DateTime?
  status           String    @default("OPEN")
  submittedAt      DateTime?
  proofUrl         String?
  proofHash        String?
  visualScore      Float?
  audioScore       Float?
  metadataPass     Boolean?
  totalConfidence  Float?
  basePayout       Float?
  precisionBonus   Float?
  totalPayout      Float?
  discoveryRake    Float?
  activeRake       Float?
  paidAt           DateTime?
  payoutTxHash     String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  campaign         Campaign  @relation(fields: [campaignId], references: [id])
  scout            Scout?    @relation(fields: [scoutId], references: [id])
}

model Scout {
  id                 String         @id @default(cuid())
  walletAddress      String         @unique
  handle             String?
  reputationScore    Int            @default(50)
  totalCampaigns     Int            @default(0)
  successfulSlots    Int            @default(0)
  failedSlots        Int            @default(0)
  tier               String         @default("BLOODHOUND")
  totalDiscoveryRake Float          @default(0)
  totalActiveRake    Float          @default(0)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  slots              CampaignSlot[]
  activeCreators     ScoutCreator[] @relation("ActiveScout")
  discoveredCreators ScoutCreator[] @relation("DiscoveryScout")
  discoveredVenues   Venue[]          @relation("VenueDiscoveryScout")
  activeVenues       Venue[]          @relation("VenueActiveScout")
  rakeEvents         ScoutRakeEvent[]
}

// Money ledger for scout rake — auditable, idempotent, clawback-able.
// Every cent traces to a settled B2B payment, vests, and can be reversed.
// Scout.totalDiscoveryRake / totalActiveRake become denormalized sums of this.
model ScoutRakeEvent {
  id         String    @id @default(cuid())
  scoutId    String
  venueId    String?
  kind       String    // DISCOVERY | ACTIVE
  sourceType String    @default("B2B_PAYMENT")
  sourceId   String    // the settled payment id
  amount     Float
  status     String    @default("PENDING") // PENDING | VESTED | CLAWED_BACK
  vestsAt    DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  scout      Scout     @relation(fields: [scoutId], references: [id])

  @@unique([scoutId, sourceId, kind])
  @@index([scoutId])
  @@index([venueId])
  @@index([status])
}

model ScoutCreator {
  id                       String   @id @default(cuid())
  creatorAddress           String   @unique
  creatorHandle            String?
  discoveryScoutId         String
  discoveredAt             DateTime @default(now())
  activeScoutId            String?
  lastActiveAt             DateTime @default(now())
  totalCompletions         Int      @default(0)
  bindingStatus            String   @default("BOUND")
  totalDiscoveryRakeEarned Float    @default(0)
  totalActiveRakeEarned    Float    @default(0)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  activeScout              Scout?   @relation("ActiveScout", fields: [activeScoutId], references: [id])
  discoveryScout           Scout    @relation("DiscoveryScout", fields: [discoveryScoutId], references: [id])
}

model LivePot {
  id                 String    @id @default(cuid())
  balance            Float     @default(0)
  totalDeposited     Float     @default(0)
  totalDistributed   Float     @default(0)
  totalSlashed       Float     @default(0)
  lastDepositAt      DateTime?
  lastDistributionAt DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model PotTransaction {
  id               String   @id @default(cuid())
  type             String
  amount           Float
  balanceAfter     Float
  sourceType       String?
  sourceId         String?
  recipientAddress String?
  recipientType    String?
  description      String?
  createdAt        DateTime @default(now())
}

model LeaderboardEntry {
  id             String   @id @default(cuid())
  period         String
  periodStart    DateTime
  periodEnd      DateTime
  entityType     String
  entityAddress  String
  entityHandle   String?
  totalVolume    Float    @default(0)
  completedCount Int      @default(0)
  successRate    Float    @default(0)
  avgPayout      Float    @default(0)
  rank           Int?
  previousRank   Int?
  rewardEarned   Float    @default(0)
  rewardTxHash   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([period, periodStart, entityType, entityAddress])
}

model WeeklyRewardDistribution {
  id                 String    @id @default(cuid())
  weekStart          DateTime  @unique
  weekEnd            DateTime
  potBalanceBefore   Float
  distributionAmount Float
  potBalanceAfter    Float
  status             String    @default("PENDING")
  creatorRewards     String    @default("[]")
  scoutRewards       String    @default("[]")
  processedAt        DateTime?
  processedBy        String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

// ============================================================================
// COMMUNITY VOTING SYSTEM
// ============================================================================

model Vote {
  id            String   @id @default(cuid())
  dareId        String
  walletAddress String
  voteType      String // APPROVE or REJECT
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  dare          Dare     @relation(fields: [dareId], references: [id], onDelete: Cascade)

  @@unique([dareId, walletAddress])
  @@index([dareId])
  @@index([walletAddress])
}

model VoterPoints {
  id            String   @id @default(cuid())
  walletAddress String   @unique
  totalPoints   Int      @default(0)
  correctVotes  Int      @default(0)
  totalVotes    Int      @default(0)
  streak        Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([totalPoints])
}

// Creator onboarding "Passport" — radar tuning, availability, and Signal Points.
// Tag / avatar / socials / earnings live on StreamerTag, joined by walletAddress.
model CreatorPassport {
  id                String   @id @default(cuid())
  walletAddress     String   @unique
  homeZone          String?
  vibeLine          String?
  missionStyles     String[] @default([])
  availability      String[] @default([])
  radiusKm          Int?
  signalPoints      Int      @default(0)
  completedMissions String[] @default([])
  pingsEnabled      Boolean  @default(false)
  routeReady        Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([signalPoints])
}

// Auditable Signal Points ledger (reputation only — no token/cash value).
// One row per awarded action; the unique key makes awards idempotent (no
// double-award / farm-by-retry). Passport.signalPoints = mission points + sum here.
model PointsEvent {
  id            String   @id @default(cuid())
  walletAddress String
  type          String // e.g. 'vault_review'
  sourceId      String // dedupe scope (e.g. venueId) — one award per (wallet,type,sourceId)
  points        Int
  createdAt     DateTime @default(now())

  @@unique([walletAddress, type, sourceId])
  @@index([walletAddress])
}

// ============================================================================
// IN-APP NOTIFICATIONS
// ============================================================================

model Notification {
  id        String   @id @default(cuid())
  wallet    String // Target wallet address
  type      String // E.g., 'DARE_CREATED', 'DARE_FUNDED', 'DARE_VERIFIED', 'DARE_FAILED'
  title     String
  message   String
  link      String? // Optional URL to redirect to
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([wallet, isRead])
  @@index([createdAt])
}

model InboxThread {
  id                 String         @id @default(cuid())
  type               String         @default("DIRECT")
  subject            String?
  participantWallets String[]       @default([])
  createdByWallet    String
  venueId            String?
  dareId             String?
  campaignId         String?
  status             String         @default("ACTIVE")
  metadataJson       Json?
  lastMessageAt      DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  venue              Venue?         @relation(fields: [venueId], references: [id], onDelete: SetNull)
  dare               Dare?          @relation(fields: [dareId], references: [id], onDelete: SetNull)
  campaign           Campaign?      @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  messages           InboxMessage[]

  @@index([status])
  @@index([venueId])
  @@index([dareId])
  @@index([campaignId])
  @@index([lastMessageAt])
  @@index([updatedAt])
}

model InboxMessage {
  id            String      @id @default(cuid())
  threadId      String
  senderWallet  String
  body          String
  redacted      Boolean     @default(false)
  readByWallets String[]    @default([])
  metadataJson  Json?
  createdAt     DateTime    @default(now())
  thread        InboxThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
  @@index([senderWallet, createdAt])
}

model WebPushSubscription {
  id         String   @id @default(cuid())
  wallet     String
  endpoint   String   @unique
  p256dh     String
  auth       String
  topics     String[] @default(["wallet", "nearby"])
  userAgent  String?
  isActive   Boolean  @default(true)
  lastLatitude  Float?
  lastLongitude Float?
  nearbyRadiusKm Float?  @default(5)
  lastLocationAt DateTime?
  lastNearbyPushAt DateTime?
  lastNearbyPushKey String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  lastSeenAt DateTime @default(now())
  deliveries WebPushDelivery[]

  @@index([wallet, isActive])
  @@index([lastSeenAt])
  @@index([lastLocationAt])
  @@index([lastNearbyPushAt])
}

model WebPushDelivery {
  id             String               @id @default(cuid())
  subscriptionId String?
  subscription   WebPushSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  wallet         String
  topic          String
  title          String
  body           String
  url            String?
  status         String
  reason         String?
  errorMessage   String?
  createdAt      DateTime             @default(now())

  @@index([wallet, createdAt])
  @@index([topic, createdAt])
  @@index([status, createdAt])
  @@index([subscriptionId, createdAt])
}

// Night-1 Drop invite RSVP — wallet-less "claim your spot" for a games night.
// Player-facing as "Hideaway Games Night"; internally a Drop. No wallet/crypto.
model DropRsvp {
  id        String   @id @default(cuid())
  dropSlug  String   @default("hideaway-games-night")
  handle    String // public display name / @handle (shown on roster)
  contact   String // WhatsApp/IG — PRIVATE, never returned in roster
  gamePref  String   @default("either") // "pool" | "darts" | "either"
  source    String? // attribution: host / hostel / ig / owner / qr
  status    String   @default("joined") // "joined" | "waitlist"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([dropSlug, contact])
  @@index([dropSlug, status, createdAt])
}

// === Pack Mark v0 — geocaching-style organic onboarding ===
// PackMember = a PROVISIONAL pack identity (product-facing "Baretag") — wallet-less
// by design (cold-start). Links to a real wallet/StreamerTag later via the
// nullable fields below. Does NOT fork User.baseTag / StreamerTag.
model Pack {
  id        String       @id @default(cuid())
  slug      String       @unique // "siargao"
  name      String // "Siargao Pack"
  createdAt DateTime     @default(now())
  marks     Mark[]
  members   PackMember[]
  claims    PackClaim[]
}

model Mark {
  id        String      @id @default(cuid())
  packId    String
  slug      String // "secret-spot-01"
  name      String // "Secret Spot #01"
  wordHash  String // sha256(normalized word) — never plaintext, never returned by any API
  artUrl    String?
  createdAt DateTime    @default(now())
  pack      Pack        @relation(fields: [packId], references: [id], onDelete: Cascade)
  claims    PackClaim[]

  @@unique([packId, slug])
}

model PackMember {
  id             String      @id @default(cuid())
  packId         String
  handle         String // "@maya" — provisional pack identity (product calls it "Baretag")
  securedVia     String? // null | 'email' | 'whatsapp' | 'instagram' (fast-follow)
  securedContact String?
  walletAddress  String? // later: link to a real account
  streamerTagId  String? // later: link to StreamerTag
  createdAt      DateTime    @default(now())
  pack           Pack        @relation(fields: [packId], references: [id], onDelete: Cascade)
  claims         PackClaim[]

  @@unique([packId, handle])
  @@index([packId])
}

model PackClaim {
  id           String     @id @default(cuid())
  packId       String
  packMemberId String
  markId       String
  type         String     @default("claimed") // 'claimed' (+1); future 'verified' (+10) / 'qualified'
  points       Int        @default(1)
  createdAt    DateTime   @default(now())
  pack         Pack       @relation(fields: [packId], references: [id], onDelete: Cascade)
  member       PackMember @relation(fields: [packMemberId], references: [id], onDelete: Cascade)
  mark         Mark       @relation(fields: [markId], references: [id], onDelete: Cascade)

  @@unique([packMemberId, markId, type]) // idempotency: one 'claimed' per member per mark
  @@index([packId, type])
}

// ============================================================================
// FREE MEETUP LAYER (Stage 2) — standalone social layer for the existing map.
// HARD BOUNDARY: never touches settlement / payouts / bounties / requireSentinel /
// finalizeVerifiedDare / receipts. No value is ever released here. References to
// StreamerTag (Baretag) and Venue are PLAIN STRINGS validated in the API — so this
// layer is fully separate from Dare/Campaign and adds no field to any existing model.
// Location is privacy-safe by construction: only approximate/rounded coords, never
// raw device GPS. Posting/RSVP require a session-owned claimed Baretag; viewing does not.
// ============================================================================
model Meetup {
  id               String   @id @default(cuid())
  creatorBaretagId String   // StreamerTag.id — server-derived from the session, never client-trusted
  title            String
  type             String   // surf | skate | sunset | jam | dwmb | custom
  venueId          String?  // optional Venue.id (public place binding)
  placeLabel       String   // required public-place text (e.g. "Cloud 9 boardwalk")
  approxLat        Float    // ROUNDED (~3dp) or the venue's public coord — never raw device GPS
  approxLng        Float
  startTime        DateTime
  note             String?
  status           String   @default("active") // active | cancelled (expired derived at READ time from startTime)
  createdAt        DateTime @default(now())
  rsvps            MeetupRsvp[]
  reports          MeetupReport[]

  @@index([status, startTime])
  @@index([creatorBaretagId])
  @@index([venueId])
}

model MeetupRsvp {
  id        String   @id @default(cuid())
  meetupId  String
  meetup    Meetup   @relation(fields: [meetupId], references: [id], onDelete: Cascade)
  baretagId String   // StreamerTag.id — server-derived
  createdAt DateTime @default(now())

  @@unique([meetupId, baretagId]) // idempotent RSVP
  @@index([baretagId])
}

model MeetupReport {
  id                String   @id @default(cuid())
  meetupId          String?
  meetup            Meetup?  @relation(fields: [meetupId], references: [id], onDelete: Cascade)
  reportedBaretagId String?  // report a person and/or a meetup
  reporterBaretagId String
  reason            String
  createdAt         DateTime @default(now())

  @@index([meetupId])
  @@index([reportedBaretagId])
}

model MeetupBlock {
  id               String   @id @default(cuid())
  blockerBaretagId String
  blockedBaretagId String
  createdAt        DateTime @default(now())

  @@unique([blockerBaretagId, blockedBaretagId])
  @@index([blockerBaretagId])
}

// ============================================================================
// CREATOR JOURNEYS + MISSION PASSES (ALPHA)
// Separate from Dare.inviteToken, economic referrals, NextAuth User, and wallet
// authorization. This rail records discovery -> saved intent -> verified IRL
// completion without turning a marketing link into a claim or payment key.
// Raw email addresses are never stored; MissionPass.emailHmac is a keyed digest.
// ============================================================================
model CreatorAttributionLink {
  id                    String   @id @default(cuid())
  serialNumber          Int      @unique @default(autoincrement())
  slug                  String   @unique
  creatorCode           String
  contentCode           String
  campaignCode          String?
  targetType            String
  targetId              String
  targetHref            String
  participationOwner    Boolean  @default(false)
  stationCode           String?
  stationHostVenueId    String?
  attentionMode         String?
  fallbackAttentionMode String?
  minimumDensity        Int?
  densityRadiusKm       Float?
  active                Boolean  @default(true)
  createdBy             String?
  createdAt             DateTime @default(now())

  touches          AttributionTouch[]
  stationHostVenue Venue?             @relation("FieldStationHostVenue", fields: [stationHostVenueId], references: [id], onDelete: SetNull)

  @@index([creatorCode, createdAt])
  @@index([targetType, targetId, active])
  @@index([stationCode, active, createdAt])
  @@index([stationHostVenueId, active])
}

model AttributionJourney {
  id             String   @id @default(cuid())
  cookieHash     String   @unique
  status         String   @default("ACTIVE")
  participantKey String?
  firstReferrer  String?
  userAgentClass String?
  firstSeenAt    DateTime @default(now())
  lastSeenAt     DateTime @default(now())
  expiresAt      DateTime

  touches       AttributionTouch[]
  intents       ActionIntent[]
  missionPasses MissionPass[]
  events        AttributionEvent[]

  @@index([participantKey, lastSeenAt])
  @@index([status, expiresAt])
}

model AttributionTouch {
  id                     String   @id @default(cuid())
  journeyId              String
  linkId                  String?
  creatorCode             String?
  contentCode             String?
  campaignCode            String?
  targetType              String
  targetId                String
  targetHref              String
  referrer                String?
  stationCode             String?
  stationHostVenueId      String?
  requestedAttentionMode  String?
  attentionMode           String?
  densityCount            Int?
  fallbackApplied         Boolean?
  occurredAt              DateTime @default(now())

  journey           AttributionJourney      @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  link              CreatorAttributionLink? @relation(fields: [linkId], references: [id], onDelete: SetNull)
  primaryForIntents ActionIntent[]          @relation("IntentPrimaryTouch")
  stationForIntents ActionIntent[]          @relation("IntentStationTouch")
  events            AttributionEvent[]

  @@index([journeyId, occurredAt])
  @@index([linkId, occurredAt])
  @@index([creatorCode, occurredAt])
  @@index([stationCode, occurredAt])
  @@index([targetType, targetId, occurredAt])
}

model ActionIntent {
  id                 String    @id @default(cuid())
  journeyId          String
  primaryTouchId     String?
  stationTouchId     String?
  targetType         String
  targetId           String
  targetHref         String
  destinationVenueId String?
  titleSnapshot      String?
  state              String    @default("LOCKED")
  participantKey     String?
  walletAddress      String?
  canonicalIntentId  String?
  lockedAt           DateTime  @default(now())
  expiresAt          DateTime
  boundAt            DateTime?
  completedAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  journey         AttributionJourney @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  primaryTouch    AttributionTouch?  @relation("IntentPrimaryTouch", fields: [primaryTouchId], references: [id], onDelete: SetNull)
  stationTouch    AttributionTouch?  @relation("IntentStationTouch", fields: [stationTouchId], references: [id], onDelete: SetNull)
  canonicalIntent ActionIntent?      @relation("IntentMerge", fields: [canonicalIntentId], references: [id], onDelete: SetNull)
  mergedIntents   ActionIntent[]     @relation("IntentMerge")
  missionPasses   MissionPass[]
  events          AttributionEvent[]

  @@unique([journeyId, targetType, targetId])
  @@index([participantKey, state, updatedAt])
  @@index([walletAddress, targetType, targetId])
  @@index([targetType, targetId, state])
  @@index([stationTouchId])
  @@index([destinationVenueId, state])
  @@index([canonicalIntentId])
}

model MissionPass {
  id             String    @id @default(cuid())
  journeyId      String
  actionIntentId String?
  tokenHash      String    @unique
  emailHmac      String?
  purpose        String    @default("ACTION")
  deliveryMethod String
  state          String    @default("ISSUED")
  expiresAt      DateTime
  issuedAt       DateTime  @default(now())
  deliveredAt    DateTime?
  openedAt       DateTime?
  revokedAt      DateTime?
  createdAt      DateTime  @default(now())

  journey      AttributionJourney @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  actionIntent ActionIntent?      @relation(fields: [actionIntentId], references: [id], onDelete: Cascade)
  events       AttributionEvent[]

  @@index([emailHmac, state, issuedAt])
  @@index([actionIntentId, issuedAt])
  @@index([journeyId, issuedAt])
  @@index([state, expiresAt])
}

// Append-only conversion ledger. Rows are never rewritten; dedupeKey prevents
// retries/races from creating a second authoritative event.
model AttributionEvent {
  id                 String   @id @default(cuid())
  eventType          String
  dedupeKey          String   @unique
  journeyId          String?
  touchId            String?
  actionIntentId     String?
  missionPassId      String?
  creatorCode        String?
  contentCode        String?
  campaignCode       String?
  stationCode        String?
  stationHostVenueId String?
  attentionMode      String?
  destinationVenueId String?
  participantKey     String?
  targetType         String?
  targetId           String?
  metadataJson       Json?
  occurredAt         DateTime @default(now())
  createdAt          DateTime @default(now())

  journey      AttributionJourney? @relation(fields: [journeyId], references: [id], onDelete: SetNull)
  touch        AttributionTouch?   @relation(fields: [touchId], references: [id], onDelete: SetNull)
  actionIntent ActionIntent?       @relation(fields: [actionIntentId], references: [id], onDelete: SetNull)
  missionPass  MissionPass?        @relation(fields: [missionPassId], references: [id], onDelete: SetNull)

  @@index([eventType, occurredAt])
  @@index([creatorCode, occurredAt])
  @@index([stationCode, occurredAt])
  @@index([stationHostVenueId, occurredAt])
  @@index([destinationVenueId, occurredAt])
  @@index([targetType, targetId, occurredAt])
  @@index([participantKey, occurredAt])
}
