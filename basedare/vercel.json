{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "crons": [
    {
      "path": "/api/cron/retry-payouts",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/refund-expired",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/venue-report-leads",
      "schedule": "0 4 * * *"
    }
  ]
}
